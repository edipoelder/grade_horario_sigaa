{
  "manifest_version": 2,
  "name": "Grade de Horários SIGAA",
  "version": "1.1",
  "description": "Selecione turmas e visualize a grade horária semanal.",
  "permissions": [
    "activeTab",
    "https://sigaa.ufrn.br/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://sigaa.ufrn.br/sigaa/ensino/turma/busca_turma.jsf*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "109.0"
    }
  },
  "privacy_policy_url": "https://github.com/edipoelder/grade_horario_sigaa/blob/main/politica.md"
}
